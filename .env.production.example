# Public deployment values. Put real values in Render's secret manager.
NODE_ENV=production
WEBAPP_URL=https://app.example.com
NEXTAUTH_URL=https://app.example.com
DATABASE_URL=postgresql://user:password@host:5432/nexcus?sslmode=require
REDIS_URL=rediss://user:password@host:6379
NEXTAUTH_SECRET=generate-a-long-random-value
FEEDBACKOS_SESSION_SECRET=generate-a-different-long-random-value
ENCRYPTION_KEY=generate-a-long-random-value
CRON_SECRET=generate-a-long-random-value

# Required by the Formbricks-compatible service boundary. Leave unset until
# Hub/Cube are provisioned and connected to this deployment.
HUB_API_KEY=
HUB_API_URL=
CUBEJS_API_SECRET=
CUBEJS_API_URL=

# Optional provider credentials. Never place these in NEXT_PUBLIC_* variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LAUNCH=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
WEBHOOK_SIGNING_SECRET=

